# Provider credentials for the "manage everything in Terraform" stacks that don't use
# AWS IAM. Copy to `.env` (gitignored) and fill in real values. AWS itself does NOT go
# here — it comes from ~/.aws profiles (watch-ro for plan/verify, watch-bootstrap for
# the temporary bootstrap applies).
#
# Terragrunt does not auto-load this file. Export it into the shell before running the
# github/cloudflare stacks:
#
#     set -a; source .env; set +a
#     AWS_PROFILE=watch-ro terragrunt plan        # in account/github or the cloudflare stack
#
# Tokens are least-privilege and short-lived where possible; rotate freely (no resource
# references them — they only authenticate the providers).

# --- GitHub (platform#15: repos as code via the `github` provider) ---
# gotoplanb is a personal account (not an org). Fine-grained PAT:
#   Resource owner = gotoplanb
#   Repository access = "Only select repositories" -> watch, platform
#     (NOT "Public repositories" — that's read-only and exposes no Repository perms)
#   Repository permissions:
#     Administration = Read/write  (settings, rulesets, collaborators, repo create)
#     Issues         = Read/write  (labels-as-code: github_issue_labels)
#     Variables      = Read/write  (Actions variables: OIDC role ARNs)
#     Metadata       = Read-only   (auto)
#   Account permissions: none
# Per GitHub REST permissions (API 2026-03-10): labels need Issues:write, Actions
# variables need Variables:write — Administration alone is not enough for #15.
# The provider reads GITHUB_TOKEN (and GITHUB_OWNER) from the environment.
GITHUB_TOKEN=
GITHUB_OWNER=gotoplanb

# --- Cloudflare (platform#13: DNS + TLS via the `cloudflare` provider) ---
# API token scoped to the zone (DNS edit). Added when #13 lands.
CLOUDFLARE_API_TOKEN=

# --- Grafana Cloud (platform#19: prod telemetry -> managed vendor, ADR-016 §2) ---
# The prod Alloy gateway exports OTLP to Grafana Cloud. Unlike the provider creds above (which
# only authenticate a provider and are referenced by no resource), these are read by
# prod/gateway/terragrunt.hcl via get_env() and passed as stack inputs — Terraform then creates
# the *token* as an SSM SecureString (value from the env var, so it lands in encrypted state,
# same class as the random_password secrets). Rotating the token = update .env + re-apply.
# Only the token is secret; endpoint + instance id are config, kept here for one private place.
# From Grafana Cloud -> Connections -> OpenTelemetry (OTLP):
#   endpoint     e.g. https://otlp-gateway-prod-us-east-0.grafana.net/otlp   (base, no /v1/...)
#   instance id  numeric stack id, used as the OTLP basic-auth username
#   token        a Cloud Access Policy token (glc_...) with scope traces:write
#                (add metrics:write / logs:write if you want those signals later)
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_INSTANCE_ID=
GRAFANA_CLOUD_TOKEN=
