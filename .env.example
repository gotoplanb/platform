# Provider credentials for the "manage everything in Terraform" stacks that don't use
# AWS IAM. Copy to `.env` (gitignored) and fill in real values. AWS itself does NOT go
# here — it comes from ~/.aws profiles (watch-ro for plan/verify, watch-bootstrap for
# the temporary bootstrap applies).
#
# Terragrunt does not auto-load this file. Export it into the shell before running the
# github/cloudflare stacks:
#
#     set -a; source .env; set +a
#     AWS_PROFILE=watch-ro terragrunt plan        # in account/github or the cloudflare stack
#
# Tokens are least-privilege and short-lived where possible; rotate freely (no resource
# references them — they only authenticate the providers).

# --- GitHub (platform#15: repos as code via the `github` provider) ---
# gotoplanb is a personal account (not an org). Fine-grained PAT:
#   Resource owner = gotoplanb
#   Repository access = "Only select repositories" -> watch, platform
#     (NOT "Public repositories" — that's read-only and exposes no Repository perms)
#   Repository permissions:
#     Administration = Read/write  (settings, rulesets, collaborators, repo create)
#     Issues         = Read/write  (labels-as-code: github_issue_labels)
#     Variables      = Read/write  (Actions variables: OIDC role ARNs)
#     Metadata       = Read-only   (auto)
#   Account permissions: none
# Per GitHub REST permissions (API 2026-03-10): labels need Issues:write, Actions
# variables need Variables:write — Administration alone is not enough for #15.
# The provider reads GITHUB_TOKEN (and GITHUB_OWNER) from the environment.
GITHUB_TOKEN=
GITHUB_OWNER=gotoplanb

# --- Cloudflare (platform#13: DNS + TLS via the `cloudflare` provider) ---
# API token scoped to the zone (DNS edit). Added when #13 lands.
CLOUDFLARE_API_TOKEN=

# --- Public DNS zone (live-verify) ---
# The zone the app/status hostnames hang off: watch[-stg].<zone> and status[-stg].<zone>. Read by
# scripts/live-verify.sh so the domain isn't hardcoded in the script (point it at your own zone).
# Not secret; kept here (gitignored) for multi-dev. Set to your real zone in .env.
WATCH_ZONE=example.com

# --- Grafana Cloud (platform#19: prod telemetry -> managed vendor, ADR-016 §2) ---
# The prod Alloy gateway exports OTLP to Grafana Cloud. Paste the two env vars exactly as Grafana
# gives them (Grafana Cloud -> Connections -> OpenTelemetry (OTLP) -> the "OTEL_EXPORTER_OTLP_*"
# block). prod/gateway/terragrunt.hcl reads them via get_env(): the endpoint is config; the
# Authorization header (whose base64 already encodes instanceID:token) is the secret. The header
# is URL-encoded per the OTel spec — Grafana emits "Authorization=Basic%20<base64>". Terraform
# strips "Authorization=" and turns %20 back into a space, storing "Basic <base64>" as an SSM
# SecureString that the gateway sends as an OTLP request header. Rotating creds = regenerate in
# Grafana, update .env, re-apply. Paste both exactly as Grafana gives them (keep the quotes).
#   OTEL_EXPORTER_OTLP_ENDPOINT   e.g. "https://otlp-gateway-prod-us-east-0.grafana.net/otlp"
#   OTEL_EXPORTER_OTLP_HEADERS    e.g. "Authorization=Basic%20<base64>"
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# --- Multi-account split (platform#22, ADR-020) ---
# The two member-account IDs the root terragrunt.hcl routes stacks into (via get_env in
# accounts.hcl). Kept here (gitignored), not in the repo — account ids aren't secret but the repo
# is public and there's no reason to publish them. Blank = the seam stays gated (single-account
# behaviour); fill them only at CUTOVER (teardown mgmt -> fill -> make live). The management
# account is read at runtime via get_aws_account_id(), so it isn't listed here.
WATCH_NONPROD_ACCOUNT_ID=   # watch-platform (staging + platform/build plane)
WATCH_PROD_ACCOUNT_ID=      # watch-prod (product-prod plane)
