# Terraform / OpenTofu / Terragrunt
.terraform/
# .terraform.lock.hcl IS committed (pins provider versions/checksums — reproducible IaC)
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terragrunt-cache/
tofu.log

# Credentials / secrets — never commit
.env
.env.*
# keep the committed template (no real values)
!.env.example
*.pem
*_rsa
*.auto.tfvars

# Local AWS portal — real config may hold account ids; keep only the .example
scripts/aws-portal.json

# OS / editor
.DS_Store
.idea/
.vscode/

# Generated Lambda placeholder package
modules/**/handler.zip

modules/**/*.zip

# Claude Code personal (per-user) overrides — keep the checked-in policy authoritative
.claude/settings.local.json

# Repo-pinned OpenTofu binary (scripts/tofu-pin.sh); see .opentofu-version
.bin/
